# BraDypUS API test suite — variables for test.sh (isolated Docker project on port 8081).
# Do NOT edit manually; this file is used exclusively by test.sh.
# For ad-hoc local runs against port 8080, use vars.env (or vars.local.env).

BASE_URL=http://localhost:8081
APP_NAME=bdus_test_suite
ADMIN_EMAIL=test@bdus.test
ADMIN_PASSWORD=TestBdus_2025!

# Root directory of bdus-api (where projects/ lives).
# Relative to this file: tests/api/ is two levels up from the repo root.
API_DIR=../..

# DB engine for the create-app call (Phase 1).
# test.sh --db=pgsql overwrites these by appending to a temp copy of this file.
DB_ENGINE=sqlite
DB_HOST=
DB_PORT=
DB_NAME=
DB_USERNAME=
DB_PASSWORD=
