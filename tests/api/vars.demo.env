# BraDypUS demo seed — variables for run_demo_seed.sh against the dev server.
# Points to localhost:8080 (dev server, port forwarded from the bradypus-app-1 container).
# Creates a standalone demo app called bdus_demo suitable for screenshots and docs.

BASE_URL=http://localhost:8080
APP_NAME=bdus_demo
ADMIN_EMAIL=admin@example.com
ADMIN_PASSWORD=Admin1234!

# Root directory of bdus-api (where projects/ lives).
API_DIR=../..

DB_ENGINE=sqlite
DB_HOST=
DB_PORT=
DB_NAME=
DB_USERNAME=
DB_PASSWORD=
