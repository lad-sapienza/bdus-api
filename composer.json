{
    "name": "bdus/api",
    "description": "BraDypUS — open-source web database system for archaeological and cultural-heritage research (PHP backend)",
    "version": "5.0.1",
    "license": "AGPL-3.0-only",
    "authors": [
        {
            "name": "Julian Bogdani",
            "email": "julian.bogdani@uniroma1.it",
            "homepage": "https://lad.saras.uniroma1.it",
            "role": "Developer"
        }
    ],
    "homepage": "https://bdus.cloud",
    "support": {
        "issues": "https://github.com/lad-sapienza/bdus-api/issues",
        "source": "https://github.com/lad-sapienza/bdus-api",
        "docs": "https://docs.bdus.cloud"
    },
    "keywords": [
        "archaeology",
        "cultural heritage",
        "database",
        "web application",
        "digital humanities",
        "api",
        "rest"
    ],
    "require": {
        "php": ">=8.2",
        "firebase/php-jwt": "^7.0",
        "intervention/image": "^3.0",
        "monolog/monolog": "^3.0",
        "adbario/php-dot-notation": "^3.0",
        "spatie/db-dumper": "^3.0",
        "funiq/geophp": "dev-master",
        "nikic/fast-route": "^1.3",
        "league/oauth2-google": "^5.0"
    },
    "require-dev": {
        "phpunit/phpunit": "^11"
    },
    "config": {
        "platform": {
            "php": "8.2"
        }
    },
    "autoload": {
        "psr-4": {
            "": "lib/",
            "Bdus\\Controllers\\": "controllers/"
        }
    },
    "autoload-dev": {
        "psr-4": {
            "Tests\\": "tests/"
        }
    }
}
