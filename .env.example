# BraDypUS backend environment variables
# Copy this file to .env and adjust the values, or set these as real environment
# variables in your server / Docker configuration.

# ── Debug ────────────────────────────────────────────────────────────────────
# Set to 1 to enable verbose PHP errors, detailed JSON error responses, and
# (when Twig is used) Twig debug mode.
BRADYPUS_DEBUG=0

# ── CORS ─────────────────────────────────────────────────────────────────────
# Space-separated list of allowed cross-origins for the JSON API.
# Required only when the Vue frontend is served from a different origin than
# the PHP backend (e.g. GitHub Pages, a dedicated Vite dev server, or a CDN).
# Leave empty (or unset) when both are on the same origin.
#
# Examples:
#   BRADYPUS_CORS_ORIGIN=https://myorg.github.io
#   BRADYPUS_CORS_ORIGIN=https://myorg.github.io https://localhost:5173
BRADYPUS_CORS_ORIGIN=
